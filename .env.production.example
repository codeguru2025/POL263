# Production environment — copy to .env on your server and fill in the values.
# Do not commit .env to git (it should be in .gitignore).

NODE_ENV=production
PORT=5000
HOST=0.0.0.0

# Required: PostgreSQL connection.
# For Supabase: Supabase → Settings → Database → Connection string → URI. Use "Connection pooling" (port 6543).
# Replace [YOUR-PASSWORD] with your Supabase database password (Settings → Database → Database password). Not the anon key.
# Example (replace YOUR-PASSWORD and region if different):
# DATABASE_URL=postgresql://postgres.PROJECT_REF:YOUR-PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@localhost:5432/pol263

# Optional: Supabase project URL and anon key (for future client/realtime use; backend uses DATABASE_URL above).
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key

# Required in production: long random string for session encryption. Generate with: npm run generate-secret
SESSION_SECRET=paste_the_output_of_npm_run_generate_secret_here

# Optional: Google OAuth for staff login (get from https://console.cloud.google.com/apis/credentials).
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GOOGLE_CALLBACK_URL=https://yourdomain.com/api/auth/google/callback

# Optional: enable demo login (only use for testing; leave unset or false in production).
# ENABLE_DEMO_LOGIN=false

# Database: run migrations/setup separately before starting the app (see docs/DATABASE-SETUP.md).
# Do not run schema push or seed from the app in production.

# ─── Paynow (server-side only; never expose Integration Key to client) ───
# PAYNOW_INTEGRATION_ID=your-integration-id
# PAYNOW_INTEGRATION_KEY=your-integration-key
# PAYNOW_RETURN_URL=https://yourdomain.com/client/payments/return
# PAYNOW_RESULT_URL=https://yourdomain.com/api/payments/paynow/result
# PAYNOW_MODE=test
# PAYMENTS_PAYNOW_ENABLED=true

# ─── Receipts (thermal 80mm) ───
# RECEIPT_ISSUER_NAME=Thobela Nexus
# RECEIPT_FOOTER_TEXT=Thank you for your payment.
# RECEIPT_CONTACTS=

# ─── App URLs (for redirects and links) ───
# APP_BASE_URL=https://yourdomain.com
# API_BASE_URL=https://yourdomain.com

# SECURITY: If Paynow Integration Key is ever exposed, rotate it immediately in Paynow dashboard and update PAYNOW_INTEGRATION_KEY here.

# ─── MULTI-TENANT ARCHITECTURE ───────────────────────────────────────────────

# Control plane database (pol263-control-plane on DigitalOcean).
# Stores: tenant registry, DB routing, integration configs, branding, feature flags.
# App connections → pooler port | DigitalOcean → Databases → pol263-control-plane → Connection string (pooler)
CONTROL_PLANE_DATABASE_URL=postgresql://YOUR_CP_USER:YOUR_CP_PASSWORD@YOUR_CP_HOST:POOLER_PORT/pol263-control-plane?sslmode=require
# Migrations → direct port | DigitalOcean → Databases → pol263-control-plane → Connection string (direct)
CONTROL_PLANE_DIRECT_URL=postgresql://YOUR_CP_USER:YOUR_CP_PASSWORD@YOUR_CP_HOST:DIRECT_PORT/pol263-control-plane?sslmode=require

# Default tenant database (pol263 on DigitalOcean).
# Tenants without an isolated DB use this. DATABASE_URL should point here in prod.
# App connections → pooler port
DATABASE_URL=postgresql://YOUR_DO_USER:YOUR_DO_PASSWORD@YOUR_DO_HOST:POOLER_PORT/pol263?sslmode=require
# Migrations → direct port
DATABASE_DIRECT_URL=postgresql://YOUR_DO_USER:YOUR_DO_PASSWORD@YOUR_DO_HOST:DIRECT_PORT/pol263?sslmode=require

# Supabase source (only needed during migration window — remove after migration verified).
# SUPABASE_DATABASE_URL=postgresql://postgres.PROJECT_REF:YOUR-PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require

# Base domain for subdomain tenant resolution (e.g. acme.pol263.app → tenant "acme").
APP_BASE_DOMAIN=pol263.app

# Encryption key for tenant secrets in control plane.
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TENANT_CONFIG_ENCRYPTION_KEY=64_hex_chars_generate_with_command_above

# Scale tuning
# MAX_TENANT_POOLS=50
# DB_POOL_MAX=25

# ─── OBJECT STORAGE (DigitalOcean Spaces / S3-compatible) ────────────────────

DO_SPACES_ENDPOINT=https://YOUR_REGION.digitaloceanspaces.com
DO_SPACES_REGION=YOUR_REGION
DO_SPACES_BUCKET=YOUR_BUCKET_NAME
DO_SPACES_KEY=YOUR_SPACES_ACCESS_KEY
DO_SPACES_SECRET=YOUR_SPACES_SECRET_KEY

# ─── WHATSAPP (per-tenant config lives in control plane — these are system-level fallback) ──
# WHATSAPP_PHONE_NUMBER_ID=...
# WHATSAPP_ACCESS_TOKEN=...
# WHATSAPP_WEBHOOK_VERIFY_TOKEN=...

# ─── SMS (per-tenant config lives in control plane — these are system-level fallback) ──
# SMS_PROVIDER=bulksms
# SMS_API_TOKEN=...
# SMS_SENDER_ID=POL263
