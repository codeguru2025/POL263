# Local development template — copy to .env and fill in real values.
# Never commit .env to git (it is in .gitignore).

NODE_ENV=development
PORT=5000

# ─── DATABASES ───────────────────────────────────────────────────────────────
# SECURITY: DATABASE_URL and CONTROL_PLANE_DATABASE_URL must use a least-privilege
# application role (e.g. pol263_app), NOT the doadmin superuser.
# doadmin credentials must only appear in *_DIRECT_URL (migration-only connections).
# A least-privilege role should have: SELECT, INSERT, UPDATE, DELETE on app tables only.
# CREATE the role in psql: CREATE ROLE pol263_app LOGIN PASSWORD '...';
#                          GRANT SELECT,INSERT,UPDATE,DELETE ON ALL TABLES IN SCHEMA public TO pol263_app;

# Active tenant DB — use a least-privilege app role here, not doadmin.
# During development: use Supabase pooler URL (port 6543).
# After migration to DigitalOcean: use pol263 pooler URL (port 25061).
DATABASE_URL=postgresql://pol263_app:PASSWORD@HOST:PORT/DATABASE?sslmode=require

# DigitalOcean pol263 — direct connection for migrations ONLY (port 25060, DDL only).
DATABASE_DIRECT_URL=postgresql://doadmin:PASSWORD@pol263-do-user-XXXX-0.f.db.ondigitalocean.com:25060/defaultdb?sslmode=require

# Control plane DB — pooler for app (port 25061) — use app role, not doadmin.
CONTROL_PLANE_DATABASE_URL=postgresql://pol263_app:PASSWORD@pol263-control-plane-do-user-XXXX-0.f.db.ondigitalocean.com:25061/defaultdb?sslmode=require

# Control plane DB — direct for migrations ONLY (port 25060).
CONTROL_PLANE_DIRECT_URL=postgresql://doadmin:PASSWORD@pol263-control-plane-do-user-XXXX-0.f.db.ondigitalocean.com:25060/defaultdb?sslmode=require

# Falakhe dedicated DB (pol263-falakhe on DigitalOcean).
# Pooler for app connections (port 25061) — use app role, not doadmin.
FALAKHE_DATABASE_URL=postgresql://pol263_app:PASSWORD@pol263-falakhe-do-user-XXXX-0.f.db.ondigitalocean.com:25061/pol263-falakhe?sslmode=require
# Direct for migrations ONLY (port 25060).
FALAKHE_DIRECT_URL=postgresql://doadmin:PASSWORD@pol263-falakhe-do-user-XXXX-0.f.db.ondigitalocean.com:25060/defaultdb?sslmode=require

# Supabase source DB — used only by migration scripts. Remove after migration.
SUPABASE_DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-eu-central-1.pooler.supabase.com:6543/postgres?sslmode=require

# ─── SESSION ─────────────────────────────────────────────────────────────────

# Generate with: npm run generate-secret
SESSION_SECRET=your-dev-session-secret

# ─── GOOGLE OAUTH (staff login) ──────────────────────────────────────────────

# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback
# APP_BASE_URL=http://localhost:5000

# ─── PAYNOW ──────────────────────────────────────────────────────────────────

# PAYNOW_INTEGRATION_ID=
# PAYNOW_INTEGRATION_KEY=
# PAYNOW_RETURN_URL=http://localhost:5000/client/payments/return
# PAYNOW_RESULT_URL=http://localhost:5000/api/payments/paynow/result
# PAYNOW_MODE=test
# PAYMENTS_PAYNOW_ENABLED=true

# ─── RECEIPT BRANDING ────────────────────────────────────────────────────────

# RECEIPT_ISSUER_NAME=
# RECEIPT_FOOTER_TEXT=

# ─── MULTI-TENANT ARCHITECTURE ───────────────────────────────────────────────

# Subdomain tenant resolution. Dev: localhost | Prod: your domain e.g. pol263.app
APP_BASE_DOMAIN=localhost

# Encryption key for tenant secrets stored in control plane.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TENANT_CONFIG_ENCRYPTION_KEY=generate_with_command_above

# ─── OBJECT STORAGE (DigitalOcean Spaces / S3-compatible) ────────────────────
# All uploads (logos, signatures, receipts, documents) go to Spaces and are served via CDN.
# Without these vars the app falls back to local disk (development only).

DO_SPACES_ENDPOINT=https://YOUR_REGION.digitaloceanspaces.com
DO_SPACES_REGION=YOUR_REGION
DO_SPACES_BUCKET=YOUR_BUCKET_NAME
DO_SPACES_KEY=YOUR_SPACES_ACCESS_KEY
DO_SPACES_SECRET=YOUR_SPACES_SECRET_KEY
# CDN endpoint — enable CDN on your Space in the DO control panel, then set this.
# Format: https://YOUR_BUCKET_NAME.YOUR_REGION.cdn.digitaloceanspaces.com
# DO_SPACES_CDN_URL=https://YOUR_BUCKET_NAME.YOUR_REGION.cdn.digitaloceanspaces.com

# ─── SMTP EMAIL (payslip delivery, notifications) ────────────────────────────
# Required for sending payslips by email.
# Works with any SMTP provider: Gmail (App Password), Zoho, Outlook, Mailgun SMTP, etc.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=youraddress@gmail.com
# SMTP_PASS=your-app-password
# EMAIL_FROM=youraddress@gmail.com

# ─── WHATSAPP (per-tenant config lives in control plane — fallback/dev only) ─

# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# ─── SMS (per-tenant config lives in control plane — fallback/dev only) ──────

# SMS_PROVIDER=bulksms
# SMS_API_TOKEN=
# SMS_SENDER_ID=POL263

# ─── SCALE TUNING ────────────────────────────────────────────────────────────

# DB_POOL_MAX=25
# MAX_TENANT_POOLS=50
# DASHBOARD_MAX_ROWS=50000
# REPORT_EXPORT_MAX_ROWS=15000

# ─── BACKGROUND JOB TUNING ───────────────────────────────────────────────────

# Max concurrent background jobs (default: 5)
# JOB_MAX_CONCURRENT=5
# Max queued-but-not-yet-started jobs before new ones are dropped (default: 500)
# JOB_MAX_PENDING=500

# ─── SECURITY FLAGS ──────────────────────────────────────────────────────────

# Set to "true" once MFA is enforced on the platform owner account via your
# identity provider (Google Workspace, etc.). Suppresses the production startup warning.
# PLATFORM_OWNER_MFA_ENFORCED=true

# ─── SSL / TLS ────────────────────────────────────────────────────────────────
# Set to "true" when connecting to DigitalOcean managed databases (self-signed cert chain).
# DB_ACCEPT_SELF_SIGNED=true

# ─── DAILY BACKUP SYNC (mirrors changes to Supabase as disaster recovery) ────
# Set this to your Supabase pooler URL. The app will upsert the last 24h of data
# to this DB every night at midnight (UTC+2). If not set, backups are skipped.
# SUPABASE_BACKUP_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-eu-central-1.pooler.supabase.com:6543/postgres?sslmode=require

# ─── SUPABASE (legacy migration source — not used in production) ──────────────
# Used only by scripts in /script/ when migrating data from the old Supabase DB.
# SUPABASE_HOST=db.<project-ref>.supabase.co
# SUPABASE_PASSWORD=
