# Local development — copy to .env and fill in.
# Do not commit .env (it is in .gitignore).

NODE_ENV=development
PORT=5000

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/your_db

# Session (generate with: npm run generate-secret)
SESSION_SECRET=your-dev-session-secret

# Optional: Google OAuth
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...
# GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Optional: Paynow (server-side only; never expose Integration Key to client)
# PAYNOW_INTEGRATION_ID=...
# PAYNOW_INTEGRATION_KEY=...
# PAYNOW_RETURN_URL=http://localhost:5000/client/payments/return
# PAYNOW_RESULT_URL=http://localhost:5000/api/payments/paynow/result
# PAYNOW_MODE=test
# PAYMENTS_PAYNOW_ENABLED=true

# Optional: Receipt branding
# RECEIPT_ISSUER_NAME=Thobela Nexus
# RECEIPT_FOOTER_TEXT=Thank you for your payment.

# SECURITY: If Paynow Integration Key is ever exposed, rotate it in the Paynow dashboard and update PAYNOW_INTEGRATION_KEY here.
