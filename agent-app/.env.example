# Copy to .env and fill in real values. Never commit .env.

# API_BASE for the app's fetch client (src/config.ts) — falls back to a LAN dev address if unset.
EXPO_PUBLIC_API_BASE=http://192.168.9.138:5000

# Google Maps SDK for Android key (Google Cloud Console, restricted to "Maps SDK for Android"
# and this app's package name / release SHA-1). Only needed for the dispatcher map screen
# (app/(app)/dispatcher-map.tsx); every other screen works without it. Read by app.config.js
# at build/prebuild time, not at JS runtime — do NOT prefix with EXPO_PUBLIC_.
GOOGLE_MAPS_ANDROID_API_KEY=
