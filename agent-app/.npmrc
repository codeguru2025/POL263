# expo-router bundles web-only tooling (@radix-ui/*, vaul) that peer-depends on react-dom,
# which this native-only project never installs — a real, structural peer conflict, not a
# version mismatch to "fix". Every local install this session used --legacy-peer-deps to work
# around it; this makes that persistent so `npm ci` (used by EAS Build, which doesn't accept
# CLI flags we don't control) resolves the same way instead of failing outright.
legacy-peer-deps=true
